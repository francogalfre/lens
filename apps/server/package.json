{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc --noEmit",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "bun run --hot src/index.ts",
		"start": "bun run dist/index.mjs"
	},
	"dependencies": {
		"@hono/trpc-server": "^0.4.0",
		"@lens/api": "workspace:*",
		"@lens/auth": "workspace:*",
		"@lens/db": "workspace:*",
		"@lens/env": "workspace:*",
		"@trpc/server": "catalog:",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"hono": "catalog:",
		"@polar-sh/hono": "^0.5.6",
		"@polar-sh/sdk": "catalog:",
		"hono-rate-limiter": "^0.5.3",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@lens/config": "workspace:*",
		"@types/bun": "catalog:",
		"tsdown": "^0.21.9",
		"typescript": "catalog:"
	},
	"trustedDependencies": [
		"supabase"
	]
}
