import fs from "fs";
import path from "path";

const src = path.join(process.cwd(), "src/assets/icon/lens-accent-black.png");
const dest = path.join(process.cwd(), "public/favicon.ico");

if (fs.existsSync(src)) {
  fs.copyFileSync(src, dest.replace(".ico", ".png"));
  console.log("Favicon created");
}