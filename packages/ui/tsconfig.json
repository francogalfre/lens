{
	"extends": "@lens/config/tsconfig.base.json",
	"compilerOptions": {
		"jsx": "react-jsx",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"baseUrl": ".",
		"ignoreDeprecations": "6.0",
		"paths": {
			"@lens/ui/*": ["./src/*"]
		}
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": ["node_modules"]
}
