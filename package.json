{
	"name": "lens",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"typescript": "^6",
			"@types/bun": "^1.3.4",
			"hono": "^4.8.2",
			"@trpc/server": "^11.16.0",
			"better-auth": "1.5.5",
			"lucide-react": "^0.546.0",
			"next-themes": "^0.4.6",
			"react": "^19.2.3",
			"react-dom": "^19.2.3",
			"sonner": "^2.0.5",
			"@trpc/client": "^11.16.0",
			"@types/react": "^19.2.10",
			"@types/react-dom": "^19.2.3",
			"tailwindcss": "^4.1.18",
			"@polar-sh/sdk": "^0.47.0"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"db:push": "turbo -F @lens/db db:push",
		"db:studio": "turbo -F @lens/db db:studio",
		"db:generate": "turbo -F @lens/db db:generate",
		"db:migrate": "turbo -F @lens/db db:migrate",
		"check": "biome check --write .",
		"prepare": "husky"
	},
	"dependencies": {
		"@langchain/core": "^1.1.42",
		"@langchain/langgraph": "^1.2.9",
		"@lens/env": "workspace:*",
		"dotenv": "catalog:",
		"html2pdf.js": "^0.14.0",
		"jspdf": "^4.2.1",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@lens/config": "workspace:*",
		"@types/bun": "catalog:",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.2",
		"turbo": "^2.8.12",
		"typescript": "catalog:"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write ."
		]
	},
	"packageManager": "bun@1.2.17"
}
